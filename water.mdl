{UTF-8}
water level = INTEG(Faucet Flow Rate - Drain Rate, 0)
~ Liters
~ |

faucet flow rate = 0.1
~ Liters/Minute
~ |

drain rate = Drain Coefficient * Water Level
~ Liters/Minute
~ |

drain coefficient = 0.5
~ 1/Minute
~ |

********************************************************
.Control
********************************************************~
Simulation Control Parameters
|

FINAL TIME  = 100
~ Month
~ The final time for the simulation.
|

INITIAL TIME  = 0
~ Month
~ The initial time for the simulation.
|

SAVEPER  =
        TIME STEP
~ Month
~ The frequency with which output is stored.
|

TIME STEP  = 1
~ Month
~ The time step for the simulation.
|
